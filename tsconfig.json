{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@hmfw/ant-design": ["components/index.ts"]
    },
    "types": ["vite/client", "node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.tsx",
    "docs/**/*.ts",
    "docs/**/*.tsx",
    "docs/**/*.vue",
    "docs/**/*.d.ts",
    "docs/plugins/**/*.ts",
    "vite.config.ts",
    "tsup.config.ts"
  ],
  "exclude": ["node_modules", "dist", "docs-dist", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"]
}
