{
  "name": "ant-design-hmfw",
  "version": "0.1.0",
  "description": "A Vue3 UI component library based on Ant Design v6",
  "keywords": [
    "vue3",
    "ui",
    "component-library",
    "ant-design",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmfw/ant-design-hmfw.git"
  },
  "homepage": "https://hmfw.github.io/ant-design-hmfw",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css",
    "dist/style.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "tsup",
    "build:docs": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "gen:icons": "tsx scripts/generate-icons.ts",
    "prebuild:lib": "pnpm gen:icons",
    "release": "pnpm build:lib && changeset publish"
  },
  "peerDependencies": {
    "vue": ">=3.3.0 <4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vitest/coverage-v8": "^1.4.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-prism": "^2.3.0",
    "prismjs": "^1.29.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "unplugin-vue-markdown": "^0.26.2",
    "vite": "^5.4.0",
    "vitest": "^1.4.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
