{
  "name": "ant-design-hmfw",
  "version": "0.1.0",
  "description": "A Vue3 UI component library based on Ant Design v6, featuring 66 high-quality components with TypeScript support",
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "components",
    "component-library",
    "ant-design",
    "antd",
    "design-system",
    "typescript",
    "tsx",
    "ui-framework",
    "vue-components"
  ],
  "author": {
    "name": "hmfw",
    "url": "https://github.com/hmfw"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmfw/ant-design-hmfw.git"
  },
  "bugs": {
    "url": "https://github.com/hmfw/ant-design-hmfw/issues"
  },
  "homepage": "https://hmfw.github.io/ant-design-hmfw",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/ant-design-hmfw.umd.js",
  "jsdelivr": "./dist/ant-design-hmfw.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./es": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    },
    "./dist/*": "./dist/*",
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css",
    "dist/style.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib",
    "build:lib": "tsup",
    "build:docs": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "gen:icons": "tsx scripts/generate-icons.ts",
    "gen:llm": "tsx scripts/generate-llm-manifest.ts",
    "prebuild:lib": "pnpm gen:icons",
    "prebuild:docs": "pnpm gen:llm",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "analyze:treeshaking": "node scripts/test-tree-shaking.js",
    "precheck": "node scripts/prepublish-check.js",
    "verify:release": "node scripts/verify-release.js",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build:lib",
    "release": "pnpm prepublishOnly && npm publish"
  },
  "peerDependencies": {
    "vue": ">=3.3.0 <4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vitest/coverage-v8": "^1.4.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-prism": "^2.3.0",
    "prismjs": "^1.29.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "unplugin-vue-markdown": "^0.26.2",
    "vite": "^5.4.0",
    "vitest": "^1.4.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  }
}
