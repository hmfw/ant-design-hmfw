{
  "name": "@hmfw/ant-design",
  "version": "0.25.0",
  "description": "基于 Ant Design v6 的 Vue3 组件库 - A Vue3 UI component library based on Ant Design, featuring 67 high-quality components with TypeScript support",
  "keywords": [
    "vue3",
    "ant-design",
    "antd",
    "ui-components",
    "component-library",
    "typescript",
    "design-system"
  ],
  "author": {
    "name": "hmfw",
    "url": "https://github.com/hmfw"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmfw/ant-design-hmfw.git"
  },
  "bugs": {
    "url": "https://github.com/hmfw/ant-design-hmfw/issues"
  },
  "homepage": "https://hmfw.github.io/ant-design-hmfw",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/ant-design.umd.js",
  "jsdelivr": "./dist/ant-design.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./es": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css",
    "dist/style.css"
  ],
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib",
    "build:lib": "pnpm generate-theme && tsup",
    "gen:dts": "tsc -p tsconfig.dts.json",
    "postbuild:lib": "pnpm gen:dts && node scripts/fix-extensions.js",
    "build:docs": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.vue,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue,.js,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:llm": "tsx scripts/generate-llm-manifest.ts",
    "generate-theme": "tsx scripts/generate-theme-css.ts",
    "prebuild:docs": "pnpm gen:llm",
    "e2e": "playwright test",
    "size": "node scripts/analyze-bundle.js && node scripts/test-tree-shaking.ts",
    "precheck": "pnpm generate-theme && git diff --exit-code components/_theme/style/index.css && node scripts/prepublish-check.ts",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build:lib",
    "prepare": "husky",
    "e2e:clean": "rm -rf test-results playwright-report",
    "e2e:kill": "lsof -ti:5173 | xargs kill -9 2>/dev/null || true",
    "pretest:e2e": "pnpm e2e:clean",
    "e2e:cleanup": "./scripts/cleanup-e2e.sh",
    "e2e:safe": "pnpm e2e:cleanup && pnpm e2e"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.vue": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,less,scss}": [
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "vue": ">=3.3.0 <4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.1",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "markdown-it-anchor": "^9.2.1",
    "markdown-it-prism": "^4.0.0",
    "prettier": "^3.9.5",
    "prismjs": "^1.30.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "unplugin-vue-markdown": "^32.0.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-eslint-parser": "^10.4.1",
    "vue-router": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@hmfw/icons": "^1.1.2"
  }
}
